# Eduator integration page (/eduator-integration) — NEXT_PUBLIC_* values are exposed in the browser bundle.

# API root including /v1 (production: https://api.eduator.ai/v1; local dev: http://127.0.0.1:4000/v1).
NEXT_PUBLIC_EDUATOR_API_BASE_URL=https://api.eduator.ai/v1

# Optional: pre-fill full HTTP API key (ed_… secret from Eduator — third-party integrations only; not web login JWT).
NEXT_PUBLIC_EDUATOR_API_KEY=

# PersonaAI / purescan chat API (used by /assistants)
# Base URL only — routes append /chat, /v1/chat/conversations, /v1/chat/feedback, etc.
NEXT_PUBLIC_CHAT_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_KEY=
# Optional: share_link when your API still expects assistant in the body (omit if API key alone is enough)
# NEXT_PUBLIC_ASSISTANT_SHARE_LINK=my-assistant-1780156778831

# Legacy alias (still read if API_KEY is empty):
# NEXT_PUBLIC_EDUATOR_ACCESS_TOKEN=
