# Eduator integration page (/eduator-integration) — NEXT_PUBLIC_* values are exposed in the browser bundle.

# API root including /v1 (e.g. http://127.0.0.1:4000/v1).
NEXT_PUBLIC_EDUATOR_API_BASE_URL=http://127.0.0.1:4000/v1

# Optional: pre-fill full HTTP API key (ed_… secret from Eduator — third-party integrations only; not web login JWT).
NEXT_PUBLIC_EDUATOR_API_KEY=

# Legacy alias (still read if API_KEY is empty):
# NEXT_PUBLIC_EDUATOR_ACCESS_TOKEN=
