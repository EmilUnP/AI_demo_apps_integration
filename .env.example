# PersonaAI / purescan chat API (used by /assistants)
# Base URL only — routes append /v1/chat, /v1/data, /v1/feedback, etc.
NEXT_PUBLIC_CHAT_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_KEY=
# Task assistant API key (PersonaAI Guide → Task mode only)
NEXT_PUBLIC_TASK_API_KEY=
# Display name for the assistant in the demo UI
NEXT_PUBLIC_ASSISTANT_NAME=PersonaAI Guide
NEXT_PUBLIC_ASSISTANT_DESCRIPTION=PersonaAI söhbət köməkçisi
# Optional legacy share_link — v1 API resolves assistant from API key; only set if needed
# NEXT_PUBLIC_ASSISTANT_SHARE_LINK=
