# PersonaAI / purescan chat API (used by /assistants and homepage widget)
# Base URL only — routes append /v1/chat, /v1/data, /v1/feedback, /v1/tts, /v1/stt
CHAT_API_BASE_URL=http://localhost:3000/api

# Server-only API keys (never use NEXT_PUBLIC_ for secrets)
CHAT_API_KEY=
CHAT_API_KEY_2=
CHAT_API_KEY_3=
CHAT_API_KEY_4=
# Task assistant API key (PersonaAI Guide → Task mode only)
TASK_API_KEY=

# Optional legacy share_link — v1 resolves assistant from API key; only set if needed
# ASSISTANT_SHARE_LINK=

# Public display / widget settings (safe for the browser)
NEXT_PUBLIC_ASSISTANT_NAME=PersonaAI Guide
NEXT_PUBLIC_ASSISTANT_DESCRIPTION=PersonaAI söhbət köməkçisi
NEXT_PUBLIC_WIDGET_TITLE=PersonaAI
NEXT_PUBLIC_WIDGET_SUBTITLE=Ask us anything
NEXT_PUBLIC_WIDGET_GREETING=Hi! How can I help?
NEXT_PUBLIC_WIDGET_PRIMARY_COLOR=#4F46E5
NEXT_PUBLIC_WIDGET_ACCENT_COLOR=#10B981
NEXT_PUBLIC_WIDGET_POSITION=bottom-right
NEXT_PUBLIC_WIDGET_LANGUAGE=auto

# Set true to enable Assistants API request debug payloads in production
# ENABLE_CHAT_DIAGNOSTICS=true
