# Eduator integration page (/eduator-integration) — values prefixed NEXT_PUBLIC_ are exposed to the browser.

# API root including /v1 (e.g. local backend or deployed URL).
NEXT_PUBLIC_EDUATOR_API_BASE_URL=http://127.0.0.1:4000/v1

# Optional: pre-fill JWT after you copy it from POST /auth/login (dev only; treat as sensitive).
NEXT_PUBLIC_EDUATOR_ACCESS_TOKEN=

# Optional: pre-fill email on the login form (do not put passwords in NEXT_PUBLIC_*).
NEXT_PUBLIC_EDUATOR_LOGIN_EMAIL=
